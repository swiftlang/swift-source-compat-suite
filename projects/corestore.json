    {
      "action": "TestXcodeWorkspaceScheme",
      "workspace": "CoreStore.xcworkspace",
      "scheme": "CoreStore iOS",
      "destination": "platform=iOS Simulator,name=iPhone 7"
    },
    {
      "action": "TestXcodeWorkspaceScheme",
      "workspace": "CoreStore.xcworkspace",
      "scheme": "CoreStore OSX",
      "destination": "platform=macOS"
