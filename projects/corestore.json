            "source-compat"
          ],
          "platform": "Darwin"
        }
      ]
    },
    {
      "action": "BuildXcodeWorkspaceScheme",
      "workspace": "CoreStore.xcworkspace",
      "scheme": "CoreStore tvOS",
      "destination": "generic/platform=tvOS",
      "configuration": "Release",
      "xfail": [
        {
          "issue": "https://github.com/swiftlang/swift/issues/78863",
          "compatibility": [
            "4.0",
            "4.2"
          ],
          "branch": [
            "main",
            "release/6.0",
            "release/6.1",
            "release/6.2",
            "release/6.3"
          ],
          "job": [
            "source-compat"
          ],
          "platform": "Darwin"
        }
