{
  "repository": "Git",
  "url": "https://github.com/mxcl/PromiseKit.git",
  "path": "PromiseKit",
  "branch": "master",
  "maintainer": "mxcl@me.com",
  "compatibility": [
    {
      "version": "4.0",
