{
  "repository": "Git",
  "url": "https://github.com/AsyncNinja/AsyncNinja.git",
  "path": "AsyncNinja",
  "branch": "master",
  "compatibility": [
    {
      "version": "4.0",
      "commit": "efc83bd21d8c25ba3896debab5f66408f683a1e7"
    },
    {
      "version": "5.0",
